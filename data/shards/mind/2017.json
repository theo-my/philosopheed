[{"doi":"10.1093/mind/fzx047","title":"Some Possibilities in Population Axiology","authors":["Teruji Thomas"],"journal":"mind","published":"2017-12-29","volume":"127","issue":"507","pages":"807-832","abstract":"","topics":[],"si":null,"url":"https://doi.org/10.1093/mind/fzx047"},{"doi":"10.1093/mind/fzx018","title":"Equal Opportunity and Newcomb’s Problem","authors":["Ian Wells"],"journal":"mind","published":"2017-12-27","volume":"128","issue":"510","pages":"429-457","abstract":"","topics":[],"si":null,"url":"https://doi.org/10.1093/mind/fzx018"},{"doi":"10.1093/mind/fzx029","title":"Semantic Verbs Are Intensional Transitives","authors":["Justin D’Ambrosio"],"journal":"mind","published":"2017-12-21","volume":"128","issue":"509","pages":"213-248","abstract":"","topics":["language"],"si":null,"url":"https://doi.org/10.1093/mind/fzx029"},{"doi":"10.1093/mind/fzx028","title":"Lockeans Maximize Expected Accuracy","authors":["Kevin Dorst"],"journal":"mind","published":"2017-12-12","volume":"128","issue":"509","pages":"175-211","abstract":"","topics":[],"si":null,"url":"https://doi.org/10.1093/mind/fzx028"},{"doi":"10.1093/mind/fzx033","title":"Rule-Following, Meaning, and Primitive Normativity","authors":["Alexander Miller"],"journal":"mind","published":"2017-12-12","volume":"128","issue":"511","pages":"735-760","abstract":"This paper explores the prospects for using the notion of a primitive normative attitude in responding to the sceptical argument about meaning developed in chapter 2 of Saul Kripke’s Wittgenstein on Rules and Private Language. It takes as its stalking-horse the response to Kripke’s Wittgenstein developed in a recent series of important works by Hannah Ginsborg. The paper concludes that Ginsborg’s attempted solution fails for a number of reasons: it depends on an inadequate response to Kripke’s Wittgenstein’s ‘finitude’ objection to reductive dispositionalism; it erroneously rejects the idea that a speaker’s understanding of an expression guides her use; it threatens to collapse into either full-blown non-reductionism or reductive dispositionalism; and there is no motive for accepting it over forms of non-reductionism such as those developed by Barry Stroud and John McDowell.","topics":["epistemology","ethics","history","language","metaphysics"],"si":null,"url":"https://doi.org/10.1093/mind/fzx033"},{"doi":"10.1093/mind/fzx036","title":"Because Without Cause: Non-Causal Explanations in Science and Mathematics, by Marc Lange","authors":["Holly Andersen"],"journal":"mind","published":"2017-12-08","volume":"127","issue":"506","pages":"593-602","abstract":"","topics":["logic","metaphysics","philsci"],"si":null,"url":"https://doi.org/10.1093/mind/fzx036"},{"doi":"10.1093/mind/fzx032","title":"Retrieving Realism, by Hubert Dreyfus & Charles Taylor.","authors":["Taylor Carman"],"journal":"mind","published":"2017-11-24","volume":null,"issue":null,"pages":null,"abstract":"","topics":["metaphysics"],"si":null,"url":"https://doi.org/10.1093/mind/fzx032"},{"doi":"10.1093/mind/fzx040","title":"Strange Tools: Art and Human Nature, by Alva Noë","authors":["John Hyman"],"journal":"mind","published":"2017-11-14","volume":"127","issue":"506","pages":"631-631","abstract":"","topics":["aesthetics"],"si":null,"url":"https://doi.org/10.1093/mind/fzx040"},{"doi":"10.1093/mind/fzx039","title":"The Structure of Justification","authors":["Sven Rosenkranz"],"journal":"mind","published":"2017-11-14","volume":"127","issue":"506","pages":"629-629","abstract":"","topics":["epistemology"],"si":null,"url":"https://doi.org/10.1093/mind/fzx039"},{"doi":"10.1093/mind/fzx001","title":"Contingent Existence and the Reduction of Modality to Essence","authors":["Trevor Teitel"],"journal":"mind","published":"2017-11-09","volume":"128","issue":"509","pages":"39-68","abstract":"","topics":["metaphysics"],"si":null,"url":"https://doi.org/10.1093/mind/fzx001"},{"doi":"10.1093/mind/fzx005","title":"Judgements about Thought Experiments","authors":["Alexander Geddes"],"journal":"mind","published":"2017-11-07","volume":"127","issue":"505","pages":"35-67","abstract":"","topics":["metaphil","philsci"],"si":null,"url":"https://doi.org/10.1093/mind/fzx005"},{"doi":"10.1093/mind/fzx015","title":"Elusive Externalism","authors":["Bernhard Salow"],"journal":"mind","published":"2017-11-04","volume":"128","issue":"510","pages":"397-427","abstract":"","topics":["epistemology"],"si":null,"url":"https://doi.org/10.1093/mind/fzx015"},{"doi":"10.1093/mind/fzx016","title":"The Boundary Stones of Thought: An Essay in the Philosophy of Logic, by Ian Rumfitt","authors":["Peter Fritz"],"journal":"mind","published":"2017-11-04","volume":"127","issue":"505","pages":"265-276","abstract":"","topics":["logic"],"si":null,"url":"https://doi.org/10.1093/mind/fzx016"},{"doi":"10.1093/mind/fzx023","title":"A Defence of the Resemblance Meaning of ‘What it’s like’","authors":["Richard Gaskin"],"journal":"mind","published":"2017-10-31","volume":"128","issue":"511","pages":"673-698","abstract":"It is often held to be definitive of consciousness that there is something it is like to be in a conscious state. A consensus has arisen that ‘is like’ in relevant ‘what it is like’ locutions does not mean ‘resembles’. This paper argues that the consensus is mistaken. It is argued that a recently proposed ‘affective’ analysis of these locutions fails, but that a purported rival of the resemblance analysis, the property account, is in fact compatible with it. Some of the implications of this argument are briefly explored: it is suggested that the meaning of ‘what it’s like’ does not, in itself, have any special bearing on consciousness, and that the implications for the so-called ‘hard problem’ of consciousness are deflationary.","topics":["language","mind"],"si":null,"url":"https://doi.org/10.1093/mind/fzx023"},{"doi":"10.1093/mind/fzx022","title":"Dark Ghettos: Injustice, Dissent, and Reform, by Tommie Shelby","authors":["Elizabeth Anderson"],"journal":"mind","publi