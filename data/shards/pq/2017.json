[{"doi":"10.1093/pq/pqx060","title":"Fitting-Attitude Analysis and the Logical Consequence Argument","authors":["Toni Rønnow-Rasmussen"],"journal":"pq","published":"2017-12-22","volume":"68","issue":"272","pages":"560-579","abstract":"","topics":["logic"],"si":null,"url":"https://doi.org/10.1093/pq/pqx060"},{"doi":"10.1093/pq/pqx062","title":"The Publicity of Thought","authors":["Andrea Onofri"],"journal":"pq","published":"2017-12-19","volume":"68","issue":"272","pages":"521-541","abstract":"An influential tradition holds that thoughts are public: different thinkers share many of their thoughts, and the same applies to a single subject at different times. This ‘publicity principle’ has recently come under attack. Arguments by Mark Crimmins, Richard Heck and Brian Loar seem to show that publicity is inconsistent with the widely accepted principle that someone who is ignorant or mistaken about certain identity facts will have distinct thoughts about the relevant object—for instance, the astronomer who does not know that Hesperus is Phosphorus will have two distinct thoughts Hesperus is bright and Phosphorus is bright. In this paper, I argue that publicity can be defended if we adopt a relational account on which thoughts are individuated by their mutual relations. I then go on to develop a specific relational theory—the ‘linking account’—and contrast it with other relational views.","topics":[],"si":null,"url":"https://doi.org/10.1093/pq/pqx062"},{"doi":"10.1093/pq/pqx064","title":"The Entanglement Problem and Idealization in Moral Philosophy","authors":["Olle Risberg"],"journal":"pq","published":"2017-12-19","volume":"68","issue":"272","pages":"542-559","abstract":"","topics":["ethics"],"si":null,"url":"https://doi.org/10.1093/pq/pqx064"},{"doi":"10.1093/pq/pqx057","title":"Moral Testimony: A Re-Conceived Understanding Explanation","authors":["Laura Frances Callahan"],"journal":"pq","published":"2017-12-07","volume":"68","issue":"272","pages":"437-459","abstract":"",